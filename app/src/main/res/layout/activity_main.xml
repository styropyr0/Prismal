<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg2"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="48dp">

            <TextView
                android:id="@+id/tvClock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:fontFamily="@font/dm_sans_medium"
                android:gravity="center"
                android:letterSpacing="-0.03"
                android:text="9:41"
                android:textColor="#FFFFFFFF"
                android:textSize="72sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:fontFamily="@font/dm_sans_medium"
                android:gravity="center"
                android:text="Saturday, 17 May"
                android:textColor="#FFFFFF"
                android:textSize="17sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:visibility="gone">

                <com.matrix.prismal.PrismalIconButton
                    android:id="@+id/prev"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:pib_blurRadius="2.5"
                    app:pib_iconPadding="14dp"
                    app:pib_iconSrc="@drawable/ic_prev"
                    app:pib_iconTint="#FFFFFF"
                    app:pib_ior="1.8"
                    app:pib_pressScale="0.85" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/dm_sans_medium"
                    android:text="Background"
                    android:textAlignment="center"
                    android:textColor="#E8FFFFFF"
                    android:textSize="13sp" />

                <com.matrix.prismal.PrismalIconButton
                    android:id="@+id/next"
                    android:layout_width="56dp"
                    android:layout_height="56dp"

                    app:pib_blurRadius="2.5"
                    app:pib_iconPadding="14dp"
                    app:pib_iconSrc="@drawable/ic_next"
                    app:pib_iconTint="#FFFFFF"
                    app:pib_ior="1.8"
                    app:pib_pressScale="0.85" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:clipChildren="false"
                android:gravity="center"
                android:orientation="horizontal">

                <com.matrix.prismal.PrismalSlider
                    android:id="@+id/prismalSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clipChildren="false" />

                <com.matrix.prismal.PrismalSwitch
                    android:id="@+id/prismalSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    app:psw_thumbThickness="10dp"
                    app:psw_trackHeight="31dp" />

            </LinearLayout>

            <com.matrix.prismal.PrismalSlider
                android:id="@+id/prismalSlider1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipChildren="false"
                android:visibility="gone"
                app:psl_trackColor="#F4800B" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:clipChildren="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.matrix.prismal.PrismalIconButton
                    android:id="@+id/prismalIconButton2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:visibility="gone"
                    app:pib_blurRadius="2.5"
                    app:pib_iconPadding="12dp"
                    app:pib_iconSrc="@drawable/icon"
                    app:pib_iconTint="#FFFFFF"
                    app:pib_ior="1.8"
                    app:pib_pressScale="0.85" />

                <com.matrix.prismal.PrismalFrameLayout
                    android:id="@+id/prismalFrame2"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginEnd="20dp"
                    android:layout_weight="1"
                    app:pfl_blurRadius="5"
                    app:pfl_brightness="1.3"
                    app:pfl_chromaticAberration="2"
                    app:pfl_cornerRadius="30dp"
                    app:pfl_displacementScale="50"
                    app:pfl_glassThickness="1dp"
                    app:pfl_heightTransitionWidth="10"
                    app:pfl_normalStrength="8"
                    app:pfl_shadowSoftness="0.4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans_medium"
                            android:text="Playground"
                            android:textAlignment="center"
                            android:textColor="#FFFFFF"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/dm_sans_medium"
                            android:alpha="0.9"
                            android:text="Customize the properties"
                            android:textAlignment="center"
                            android:textColor="#E6FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>

                </com.matrix.prismal.PrismalFrameLayout>

                <com.matrix.prismal.PrismalIconButton
                    android:id="@+id/prismalIconButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"

                    android:layout_marginEnd="10dp"
                    app:pib_blurRadius="2.5"
                    app:pib_iconPadding="14dp"
                    app:pib_iconSrc="@drawable/icon"
                    app:pib_iconTint="#FFFFFF"
                    app:pib_ior="1.8"
                    app:pib_pressScale="0.85" />

                <com.matrix.prismal.PrismalIconButton
                    android:id="@+id/prismalIconButton3"
                    android:layout_width="56dp"
                    android:layout_height="56dp"

                    app:pib_blurRadius="2.5"
                    app:pib_iconPadding="12dp"
                    app:pib_iconSrc="@drawable/ic_drag"
                    app:pib_iconTint="#FFFFFF"
                    app:pib_ior="1.8"
                    app:pib_pressScale="0.85" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.06"
                android:text="NOTIFICATIONS"
                android:textAllCaps="true"
                android:textColor="#99FFFFFF"
                android:textSize="12sp" />

            <com.matrix.prismal.PrismalFrameLayout
                android:id="@+id/notif1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:gravity="center"
                        android:text="💬"
                        android:textSize="22sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/dm_sans_medium"
                                android:text="Messages"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.65"
                                android:text="now"
                                android:fontFamily="@font/dm_sans_medium"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/dm_sans_medium"
                            android:alpha="0.85"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="Alex: Hey, are you coming tonight?"
                            android:textColor="#E6FFFFFF"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

            </com.matrix.prismal.PrismalFrameLayout>

            <com.matrix.prismal.PrismalFrameLayout
